'use client'

import { useState } from 'react'
import { usePlaylistStore, Song } from '@/lib/store'
import { api } from '@/lib/api'
import { SongCard } from '@/components/SongCard'
import { Button } from '@/components/ui/button'
import { Input } from '@/components/ui/input'
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card'
import { MusicalNoteIcon, SparklesIcon, CheckIcon, ArrowRightIcon } from '@heroicons/react/24/outline'
import { useRouter } from 'next/navigation'
import { useTranslations } from 'next-intl'
import { LanguageSwitcher } from '@/components/LanguageSwitcher'

const MOODS = [
  'chill', 'happy', 'sad', 'energetic', 'romantic', 'focus', 'sleep',
  'party', 'workout', 'relaxed', 'motivating', 'peaceful', 'exciting',
  'nostalgic', 'melancholic', 'upbeat', 'ambient', 'angry', 'hopeful', 'emotional'
]

const GENRES = [
  'hot', 'us_uk', 'korean', 'chinese', 'vietnam', 'japanese',
  'work_music', 'instrumental', 'sleep_music', 'baby_lullabies',
  'edm', 'rock', 'pop', 'jazz', 'classical', 'rnb', 'hiphop',
  'latin', 'indie', 'folk', 'country', 'blues', 'reggae',
  'metal', 'punk', 'disco', 'techno', 'house'
]

export default function CreatePlaylistPage() {
  const router = useRouter()
  const t = useTranslations('create')
  const tCommon = useTranslations('common')
  const tNav = useTranslations('nav')
  const { selectedSongs, addSong, removeSong, setStep, currentStep } = usePlaylistStore()

  // Step 1: Mood & Genre
  const [mood, setMood] = useState('')
  const [genre, setGenre] = useState('')
  const [customMood, setCustomMood] = useState('')
  const [customGenre, setCustomGenre] = useState('')
  const [playlistName, setPlaylistName] = useState('')

  // Step 2: Search
  const [searchQuery, setSearchQuery] = useState('')
  const [searchResults, setSearchResults] = useState<Song[]>([])
  const [isSearching, setIsSearching] = useState(false)
  const [royaltyFreeOnly, setRoyaltyFreeOnly] = useState(false)

  // Step 3: Settings
  const [audioGap, setAudioGap] = useState(5)

  const handleSearch = async () => {
    setIsSearching(true)
    try {
      const data = await api.searchMusic({
        q: searchQuery,
        mood: customMood || mood,
        genre: customGenre || genre,
        limit: 20,
        royalty_free_only: royaltyFreeOnly
      })
      setSearchResults(data.songs || [])
    } catch (error) {
      console.error('Search error:', error)
    } finally {
      setIsSearching(false)
    }
  }

  const handleToggleSong = (song: Song) => {
    const isSelected = selectedSongs.some(s => s.source_id === song.source_id)
    if (isSelected) {
      removeSong(song.source_id)
    } else {
      if (selectedSongs.length < 20) {
        addSong(song)
      }
    }
  }

  const handleNextStep = () => {
    if (currentStep < 3) {
      setStep(currentStep + 1)
    } else {
      // Generate playlist
      handleGeneratePlaylist()
    }
  }

  const handleGeneratePlaylist = async () => {
    try {
      // Create playlist
      const playlist = await api.createPlaylist({
        name: playlistName || `${mood} ${genre} playlist`,
        mood,
        genre,
        description: `${mood} music for ${genre}`
      })

      // Add songs to playlist
      for (const song of selectedSongs) {
        await api.addSongToPlaylist(playlist.id, song)
      }

      // Navigate to playlist detail
      router.push(`/playlist/${playlist.id}`)
    } catch (error) {
      console.error('Error generating playlist:', error)
    }
  }

  const isStepValid = () => {
    switch (currentStep) {
      case 1:
        return mood && genre
      case 2:
        return selectedSongs.length > 0
      case 3:
        return true
      default:
        return false
    }
  }

  return (
    <div className="min-h-screen bg-background">
      {/* Header */}
      <header className="border-b border-border bg-card">
        <div className="container-custom py-4">
          {/* Top Bar */}
          <div className="flex items-center justify-between mb-6">
            <div className="flex items-center gap-3">
              <div className="p-2 bg-primary/10 rounded-lg">
                <MusicalNoteIcon className="h-5 w-5 text-primary" />
              </div>
              <span className="text-lg font-bold text-foreground">
                {tCommon('appName')}
              </span>
            </div>
            <button
              onClick={() => router.push('/')}
              className="px-4 py-2 text-muted-foreground hover:text-foreground transition-colors font-medium"
            >
              {tCommon('back')}
            </button>
          </div>

          {/* Progress Steps */}
          <div className="flex items-center justify-center gap-2">
            {[1, 2, 3].map((step) => (
              <div key={step} className="flex items-center">
                <div className={`
                  w-10 h-10 rounded-full flex items-center justify-center font-semibold text-sm transition-all
                  ${currentStep > step
                    ? 'bg-accent text-white'
                    : currentStep === step
                      ? 'bg-primary text-white'
                      : 'bg-muted text-muted-foreground'
                  }
                `}>
                  {currentStep > step ? <CheckIcon className="h-4 w-4" /> : step}
                </div>
                {step < 3 && (
                  <div className={`w-12 h-1 mx-1 rounded-full transition-colors ${currentStep > step ? 'bg-accent' : 'bg-muted'}`} />
                )}
              </div>
            ))}
          </div>
        </div>
      </header>

      {/* Content */}
      <main className="container-custom py-8">
        {currentStep === 1 && (
          <div className="max-w-4xl mx-auto space-y-6">
            {/* Title */}
            <div className="text-center mb-8">
              <h1 className="text-3xl md:text-4xl font-bold mb-2 text-foreground">
                {t('title')}
              </h1>
              <p className="text-muted-foreground">
                {t('subtitle')}
              </p>
            </div>

            {/* Playlist Name */}
            <div className="card">
              <h2 className="text-lg font-bold mb-4 text-foreground">
                {t('playlistName')}
              </h2>
              <Input
                placeholder={t('playlistNamePlaceholder')}
                value={playlistName}
                onChange={(e) => setPlaylistName(e.target.value)}
                className="input"
              />
            </div>

            {/* Mood Selection */}
            <div className="card">
              <h2 className="text-lg font-bold mb-4 text-foreground">
                {t('selectMood')}
              </h2>
              <div className="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
                {MOODS.map((m) => (
                  <button
                    key={m}
                    onClick={() => {
                      setMood(m)
                      setCustomMood('')
                    }}
                    className={`
                      selection-btn text-sm capitalize
                      ${mood === m && !customMood ? 'selected' : ''}
                    `}
                  >
                    {t(`moods.${m}` as any)}
                  </button>
                ))}
              </div>

              {/* Custom Mood Input */}
              <div className="mt-6 pt-6 border-t border-border">
                <label className="block text-sm font-medium mb-2 text-foreground">
                  {t('customMood')} {tCommon('or')} {t('customSearch')}
                </label>
                <Input
                  placeholder={t('customMoodPlaceholder')}
                  value={customMood}
                  onChange={(e) => {
                    setCustomMood(e.target.value)
                    setMood('')
                  }}
                  className="input"
                />
              </div>
            </div>

            {/* Genre Selection */}
            <div className="card">
              <h2 className="text-lg font-bold mb-4 text-foreground">
                {t('selectGenre')}
              </h2>
              <div className="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
                {GENRES.map((g) => (
                  <button
                    key={g}
                    onClick={() => {
                      setGenre(g)
                      setCustomGenre('')
                    }}
                    className={`
                      selection-btn text-sm capitalize
                      ${genre === g && !customGenre ? 'selected' : ''}
                    `}
                  >
                    {t(`genres.${g}` as any)}
                  </button>
                ))}
              </div>

              {/* Custom Genre Input */}
              <div className="mt-6 pt-6 border-t border-border">
                <label className="block text-sm font-medium mb-2 text-foreground">
                  {t('customGenre')} {tCommon('or')} {t('customSearch')}
                </label>
                <Input
                  placeholder={t('customGenrePlaceholder')}
                  value={customGenre}
                  onChange={(e) => {
                    setCustomGenre(e.target.value)
                    setGenre('')
                  }}
                  className="input"
                />
              </div>
            </div>
          </div>
        )}

        {currentStep === 2 && (
          <div className="max-w-4xl mx-auto space-y-6">
            {/* Title */}
            <div className="text-center mb-8">
              <h1 className="text-3xl md:text-4xl font-bold mb-2 text-foreground">
                {t('selectSongs')}
              </h1>
              <p className="text-muted-foreground">
                {t('selectedCount', { count: selectedSongs.length, max: 20 })}
              </p>
            </div>

            {/* Search */}
            <div className="card">
              <div className="flex gap-3">
                <Input
                  placeholder={t('searchPlaceholder')}
                  value={searchQuery}
                  onChange={(e) => setSearchQuery(e.target.value)}
                  onKeyPress={(e) => e.key === 'Enter' && handleSearch()}
                  className="input flex-1"
                />
                <button
                  onClick={handleSearch}
                  disabled={isSearching}
                  className="btn-primary inline-flex items-center gap-2"
                >
                  {isSearching ? t('searching') : tCommon('search')}
                </button>
              </div>

              <div className="mt-4">
                <label className="flex items-center gap-2 cursor-pointer">
                  <input
                    type="checkbox"
                    checked={royaltyFreeOnly}
                    onChange={(e) => setRoyaltyFreeOnly(e.target.checked)}
                    className="w-4 h-4"
                  />
                  <span className="text-sm text-foreground">{t('royaltyFreeOnly')}</span>
                </label>
              </div>
            </div>

            {/* Search Results */}
            {searchResults.length > 0 && (
              <div className="card">
                <h2 className="text-lg font-bold mb-4 text-foreground">
                  {t('searchResults')}
                </h2>
                <div className="space-y-3">
                  {searchResults.map((song) => {
                    const isSelected = selectedSongs.some(s => s.source_id === song.source_id)
                    return (
                      <div
                        key={song.source_id}
                        onClick={() => handleToggleSong(song)}
                        className={`
                          song-card p-4 rounded-lg cursor-pointer transition-all
                          ${isSelected ? 'selected' : ''}
                        `}
                      >
                        <div className="flex items-center gap-4">
                          <div className="flex-1">
                            <p className="font-medium text-foreground">{song.title}</p>
                            <p className="text-sm text-muted-foreground">{song.artist}</p>
                          </div>
                          {isSelected && (
                            <CheckIcon className="h-5 w-5 text-primary" />
                          )}
                        </div>
                      </div>
                    )
                  })}
                </div>
              </div>
            )}

            {/* Selected Songs */}
            {selectedSongs.length > 0 && (
              <div className="card">
                <h2 className="text-lg font-bold mb-4 text-foreground">
                  {t('selectedSongs', { count: selectedSongs.length })}
                </h2>
                <div className="space-y-3">
                  {selectedSongs.map((song) => (
                    <div
                      key={song.source_id}
                      className="p-4 bg-primary/5 rounded-lg border border-primary/20"
                    >
                      <div className="flex items-center justify-between">
                        <div className="flex-1">
                          <p className="font-medium text-foreground">{song.title}</p>
                          <p className="text-sm text-muted-foreground">{song.artist}</p>
                        </div>
                        <button
                          onClick={() => removeSong(song.source_id)}
                          className="text-red-500 hover:text-red-700 font-medium text-sm px-3 py-1 rounded"
                        >
                          {t('remove')}
                        </button>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        )}

        {currentStep === 3 && (
          <div className="max-w-4xl mx-auto space-y-6">
            {/* Title */}
            <div className="text-center mb-8">
              <h1 className="text-3xl md:text-4xl font-bold mb-2 text-foreground">
                {t('options')}
              </h1>
              <p className="text-muted-foreground">
                {t('optionsSubtitle')}
              </p>
            </div>

            {/* Audio Gap */}
            <div className="card">
              <h2 className="text-lg font-bold mb-4 text-foreground">
                {t('audioGap')}
              </h2>
              <div className="space-y-4">
                <input
                  type="range"
                  min="5"
                  max="10"
                  value={audioGap}
                  onChange={(e) => setAudioGap(Number(e.target.value))}
                  className="w-full"
                />
                <p className="text-center text-lg font-semibold text-foreground">
                  {audioGap} {t('seconds')}
                </p>
              </div>
            </div>

            {/* Confirm */}
            <div className="card">
              <h2 className="text-lg font-bold mb-4 text-foreground">
                {t('confirm')}
              </h2>
              <div className="space-y-3">
                <div className="flex justify-between">
                  <span className="font-medium text-muted-foreground">{t('confirmDetails.name')}:</span>
                  <span className="text-foreground font-semibold">
                    {playlistName || `${mood} ${genre} playlist`}
                  </span>
                </div>
                <div className="flex justify-between">
                  <span className="font-medium text-muted-foreground">{t('confirmDetails.mood')}:</span>
                  <span className="text-foreground font-semibold">{mood}</span>
                </div>
                <div className="flex justify-between">
                  <span className="font-medium text-muted-foreground">{t('confirmDetails.genre')}:</span>
                  <span className="text-foreground font-semibold">{genre?.replace('_', ' ')}</span>
                </div>
                <div className="flex justify-between">
                  <span className="font-medium text-muted-foreground">{t('confirmDetails.songCount')}:</span>
                  <span className="text-foreground font-semibold">{selectedSongs.length}</span>
                </div>
                <div className="flex justify-between">
                  <span className="font-medium text-muted-foreground">{t('confirmDetails.gap')}:</span>
                  <span className="text-foreground font-semibold">{audioGap} {t('seconds')}</span>
                </div>
              </div>
            </div>
          </div>
        )}

        {/* Navigation */}
        <div className="flex justify-between mt-8 max-w-4xl mx-auto">
          <button
            onClick={() => setStep(Math.max(1, currentStep - 1))}
            disabled={currentStep === 1}
            className="px-6 py-3 rounded-lg font-medium transition-all disabled:opacity-50 disabled:cursor-not-allowed hover:bg-muted text-foreground"
          >
            {tCommon('back')}
          </button>
          <button
            onClick={handleNextStep}
            disabled={!isStepValid()}
            className="btn-primary inline-flex items-center gap-2 px-6 py-3 disabled:opacity-50 disabled:cursor-not-allowed"
          >
            {currentStep === 3 ? t('createPlaylist') : tCommon('continue')}
            {currentStep < 3 && <ArrowRightIcon className="h-4 w-4" />}
          </button>
        </div>
      </main>
    </div>
  )
}
          <div className="space-y-6">
            <div className="text-center mb-8">
              <h1 className="text-3xl font-bold mb-2">{t('selectSongs')}</h1>
              <p className="text-gray-600">
                {t('selectedCount', { count: selectedSongs.length, max: 20 })}
              </p>
            </div>

            {/* Search Bar */}
            <Card>
              <CardContent className="pt-6">
                <div className="flex gap-4">
                  <Input
                    placeholder={t('searchPlaceholder')}
                    value={searchQuery}
                    onChange={(e) => setSearchQuery(e.target.value)}
                    onKeyPress={(e) => e.key === 'Enter' && handleSearch()}
                    className="flex-1"
                  />
                  <Button onClick={handleSearch} disabled={isSearching}>
                    {isSearching ? t('searching') : tCommon('search')}
                  </Button>
                </div>

                <div className="mt-4">
                  <label className="flex items-center gap-2 cursor-pointer">
                    <input
                      type="checkbox"
                      checked={royaltyFreeOnly}
                      onChange={(e) => setRoyaltyFreeOnly(e.target.checked)}
                      className="w-4 h-4"
                    />
                    <span className="text-sm">{t('royaltyFreeOnly')}</span>
                  </label>
                </div>
              </CardContent>
            </Card>

            {/* Search Results */}
            {searchResults.length > 0 && (
              <Card>
                <CardHeader>
                  <CardTitle>{t('searchResults')}</CardTitle>
                </CardHeader>
                <CardContent>
                  <div className="space-y-3">
                    {searchResults.map((song) => {
                      const isSelected = selectedSongs.some(s => s.source_id === song.source_id)
                      return (
                        <SongCard
                          key={song.source_id}
                          song={song}
                          isSelected={isSelected}
                          onSelect={() => handleToggleSong(song)}
                          onPreview={() => console.log('Preview:', song.audio_url)}
                        />
                      )
                    })}
                  </div>
                </CardContent>
              </Card>
            )}

            {/* Selected Songs */}
            {selectedSongs.length > 0 && (
              <Card>
                <CardHeader>
                  <CardTitle>{t('selectedSongs', { count: selectedSongs.length })}</CardTitle>
                </CardHeader>
                <CardContent>
                  <div className="space-y-3">
                    {selectedSongs.map((song) => (
                      <div key={song.source_id} className="flex items-center gap-4 p-3 bg-purple-50 rounded-lg">
                        <div className="flex-1">
                          <p className="font-medium">{song.title}</p>
                          <p className="text-sm text-gray-600">{song.artist}</p>
                        </div>
                        <Button
                          variant="destructive"
                          size="sm"
                          onClick={() => removeSong(song.source_id)}
                        >
                          {t('remove')}
                        </Button>
                      </div>
                    ))}
                  </div>
                </CardContent>
              </Card>
            )}
          </div>
        )}

        {currentStep === 3 && (
          <div className="space-y-6">
            <div className="text-center mb-8">
              <h1 className="text-3xl font-bold mb-2">{t('options')}</h1>
              <p className="text-gray-600">{t('optionsSubtitle')}</p>
            </div>

            <Card>
              <CardHeader>
                <CardTitle>{t('audioGap')}</CardTitle>
              </CardHeader>
              <CardContent>
                <div className="space-y-4">
                  <input
                    type="range"
                    min="5"
                    max="10"
                    value={audioGap}
                    onChange={(e) => setAudioGap(Number(e.target.value))}
                    className="w-full"
                  />
                  <p className="text-center text-lg font-semibold">
                    {audioGap} {t('seconds')}
                  </p>
                </div>
              </CardContent>
            </Card>

            <Card>
              <CardHeader>
                <CardTitle>{t('confirm')}</CardTitle>
              </CardHeader>
              <CardContent>
                <div className="space-y-2">
                  <p><strong>{t('confirmDetails.name')}:</strong> {playlistName || `${mood} ${genre} playlist`}</p>
                  <p><strong>{t('confirmDetails.mood')}:</strong> {mood}</p>
                  <p><strong>{t('confirmDetails.genre')}:</strong> {genre?.replace('_', ' ')}</p>
                  <p><strong>{t('confirmDetails.songCount')}:</strong> {selectedSongs.length}</p>
                  <p><strong>{t('confirmDetails.gap')}:</strong> {audioGap} {t('seconds')}</p>
                </div>
              </CardContent>
            </Card>
          </div>
        )}

        {/* Navigation */}
        <div className="flex justify-between mt-12 gap-4">
          <button
            onClick={() => setStep(Math.max(1, currentStep - 1))}
            disabled={currentStep === 1}
            className="glass-strong button-press px-8 py-4 rounded-2xl font-semibold text-gray-700 dark:text-gray-300 disabled:opacity-50 disabled:cursor-not-allowed hover:scale-105 smooth-transition"
          >
            {tCommon('back')}
          </button>
          <button
            onClick={handleNextStep}
            disabled={!isStepValid()}
            className="button-press px-8 py-4 bg-gradient-to-r from-purple-600 to-indigo-600 text-white rounded-2xl font-semibold shadow-strong hover:shadow-2xl disabled:opacity-50 disabled:cursor-not-allowed hover:scale-105 smooth-transition min-w-[180px]"
          >
            {currentStep === 3 ? t('createPlaylist') : tCommon('continue')}
            {currentStep < 3 && <ArrowRightIcon className="h-5 w-5 ml-2" />}
          </button>
        </div>
      </main>
    </div>
  )
}
