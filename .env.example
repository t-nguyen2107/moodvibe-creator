# =============================================================================
# MOODVIBE CREATOR - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to:
#   - backend/.env (for backend settings)
#   - frontend/.env.local (for frontend settings)
# =============================================================================

# =============================================================================
# BACKEND SETTINGS (copy to backend/.env)
# =============================================================================

# Database
DATABASE_URL=sqlite:///./database.db

# Security - CHANGE THESE IN PRODUCTION!
SECRET_KEY=your-secret-key-here-change-in-production
MASTER_ENCRYPTION_KEY=your-32-byte-master-key-here

# File Storage
UPLOAD_DIR=../uploads
MAX_PLAYLIST_SIZE=20

# CORS
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# API Keys (Optional - users can provide their own via Settings page)
# -----------------------------------------------------------------------------
YOUTUBE_API_KEY=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
STABILITY_API_KEY=

# -----------------------------------------------------------------------------
# Spotify API (For Vietnam music charts)
# Get credentials: https://developer.spotify.com/dashboard
# -----------------------------------------------------------------------------
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# AI Provider Configuration
# -----------------------------------------------------------------------------

# Option 1: OpenAI (Paid, ~$0.15/1M tokens)
# Get API key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Option 2: Ollama (FREE, runs locally)
# Install: https://ollama.ai
# Run: ollama pull llama3
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# AI Provider: "auto", "openai", or "ollama"
AI_PROVIDER=auto

# -----------------------------------------------------------------------------
# Redis (Optional - for caching AI parse results)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Cache TTL (seconds)
CACHE_TTL_AI_PARSE=604800
CACHE_TTL_CHARTS=86400

# Rate Limiting
AI_PARSE_RATE_LIMIT=10

# =============================================================================
# FRONTEND SETTINGS (copy to frontend/.env.local)
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000

# =============================================================================
# QUICK SETUP GUIDE
# =============================================================================
# 1. Copy backend settings to backend/.env
# 2. Copy frontend settings to frontend/.env.local
# 3. Generate SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 4. Generate MASTER_ENCRYPTION_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 5. (Optional) Add API keys for YouTube, TikTok, Stable Diffusion
# 6. (Optional) Setup Ollama for free AI features
