# Database
DATABASE_URL=sqlite:///./database.db

# Security
SECRET_KEY=your-secret-key-here-change-in-production
MASTER_ENCRYPTION_KEY=your-32-byte-master-key-here

# File Storage
UPLOAD_DIR=../uploads
MAX_PLAYLIST_SIZE=20

# API Keys (Optional - users can provide their own)
YOUTUBE_API_KEY=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
STABILITY_API_KEY=

# =============================================================================
# SPOTIFY API CONFIGURATION (For Vietnam music charts)
# =============================================================================
# Get your credentials from: https://developer.spotify.com/dashboard
# 1. Create a new app
# 2. Get Client ID and Client Secret
# 3. Add redirect URI: http://localhost:8899/callback (not needed for client credentials)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# =============================================================================
# AI PROVIDER CONFIGURATION (Choose One)
# =============================================================================

# Option 1: OpenAI (Paid, ~$0.15/1M tokens)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini  # Cost-effective: $0.15/1M input tokens

# Option 2: Ollama (FREE, runs locally)
# Install Ollama from: https://ollama.ai
# Run: ollama pull llama3
OLLAMA_ENABLED=false  # Set to 'true' to use Ollama instead of OpenAI
OLLAMA_BASE_URL=http://localhost:11434  # Default Ollama endpoint
OLLAMA_MODEL=llama3  # Default model (llama3, llama3:8b, mistral, etc.)

# AI Provider Selection: "auto", "openai", or "ollama"
# - "auto": Try OpenAI first, fallback to Ollama, then keyword extraction
# - "openai": Use OpenAI only (requires API key)
# - "ollama": Use Ollama only (requires Ollama installed)
AI_PROVIDER=auto

# =============================================================================
# REDIS CONFIGURATION (Optional - for caching AI parse results)
# =============================================================================
# Highly recommended for production to reduce API costs
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=  # Leave empty if no password

# Cache TTL (seconds)
CACHE_TTL_AI_PARSE=604800  # 7 days - AI parse results don't change
CACHE_TTL_CHARTS=86400     # 24 hours - music charts change daily

# =============================================================================
# RATE LIMITING
# =============================================================================
AI_PARSE_RATE_LIMIT=10  # requests per minute per user

# CORS
FRONTEND_URL=http://localhost:3000
